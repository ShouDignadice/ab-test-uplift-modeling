# Python cache
__pycache__/
*.py[cod]
*$py.class

# Virtual environments
venv/
env/
.venv/
ENV/

# Environment variables
.env
.env.local

# OS files
.DS_Store
Thumbs.db

# IDE / editor files
.vscode/
.idea/

# Raw data files
data/
raw_data/
*.xlsx
*.xls

# Ignore CSV files by default
*.csv

# Allow output tables
!outputs/
!outputs/tables/
!outputs/tables/*.csv

# Allow output figures
!outputs/figures/
!outputs/figures/*.png

# Other output/report folders to ignore
reports/
figures/
plots/

# Ignore other image/report files outside allowed output figures
*.jpg
*.jpeg
*.pdf

# Model files
models/
*.pkl
*.joblib

# Logs
*.log

# Temporary files
tmp/
temp/
*.tmp